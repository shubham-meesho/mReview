# ── GitHub App ────────────────────────────────────────────────────────────────
# Numeric App ID shown on your GitHub App's settings page
# github.com/organizations/{org}/settings/apps/{app-name}
GITHUB_APP_ID=

# Path to the RSA private key downloaded from the GitHub App settings page
# Keep this file out of version control (already in .gitignore)
GITHUB_APP_PRIVATE_KEY_PATH=./keys/github-app.pem

# Webhook secret — set this when creating the GitHub App (Webhook section)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# API key from console.anthropic.com
ANTHROPIC_API_KEY=

# ── Routing ───────────────────────────────────────────────────────────────────
# Only PRs targeting this branch will be reviewed
TARGET_BRANCH=develop
